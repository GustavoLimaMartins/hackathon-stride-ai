# Copie este arquivo para .env e preencha com suas credenciais reais.
# O .env NÃO deve ser versionado (está no .gitignore).

# Chave de API do LLM usada pelo stride_engine (Fase 4).
OPENAI_API_KEY=

# Provedor principal dos DOIS papéis de LLM ('rewriter' e 'analyst'):
#   true  (default) = OpenAI (gpt-4o no rewriter, gpt-5 no analyst), pago, com
#                     fallback automático para Ollama no timeout de cada etapa.
#   false           = Ollama (gemma3:12b) como principal direto nos dois papéis,
#                     sem tentar a OpenAI nem exigir OPENAI_API_KEY (100% local).
LLM_MODEL_PAID=true

# Timeout (segundos) da chamada ao 'analyst' (gpt-5) antes de acionar o
# fallback local via Ollama. Default: 600 (10 min). Reduza para testar o
# fallback rapidamente (ex.: 10) ou aumente em ambientes com OpenAI mais lenta.
ANALYST_TIMEOUT_SECONDS=600

# Timeout (segundos) da etapa 'rewriter' (gpt-4o), que enriquece o grafo com um
# resumo de contexto antes do analyst. É uma síntese curta, então o teto é bem
# menor. Default: 60. Se estourar, a etapa cai para o Ollama e, se este também
# falhar, o pipeline segue SEM o resumo (etapa não crítica).
REWRITER_TIMEOUT_SECONDS=60

# --- Fallback local (Ollama) — opcional -------------------------------------
# Quando o analyst da OpenAI (gpt-5) estoura o timeout de 10 min, o app cai para
# um modelo local via Ollama (gemma3:12b). Requer o Ollama em execução e o
# modelo baixado: `ollama serve` + `ollama pull gemma3:12b`.
#
# Host do daemon Ollama (opcional; default http://localhost:11434). Ajuste para
# apontar a um servidor Ollama remoto.
OLLAMA_HOST=http://localhost:11434
