__pycache__/
*.pyc
*.pyo
.pytest_cache/
.mypy_cache/

# Artefatos do EasyOCR (modelos baixados em cache) e uploads temporários
*.tmp

# Calibração local dos tempos de cada etapa (barra de progresso) — não versionar
.stride_timings.json

# IDE / SO
.vscode/
.idea/
.DS_Store
Thumbs.db
