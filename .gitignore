# Segredos e variáveis de ambiente (chaves de API do LLM, etc.)
.env
.env.*
!.env.example

# Ambiente virtual Python
.venv/
venv/

# Artefatos de treino do Ultralytics (logs, curvas, checkpoints intermediários)
runs/
dataset_old/

